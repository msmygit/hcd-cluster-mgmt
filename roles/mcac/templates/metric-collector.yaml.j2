###
### Metric Collector for Apache Cassandra (MCAC) Configuration
### Generated by Ansible — do not edit manually
###

### Frequency that metrics are sampled and reported (seconds)
metric_sampling_interval_in_seconds: {{ mcac_sampling_interval }}

###
### Filtering rules — last matching rule wins (iptables-style)
### policy: allow | deny
### pattern: regex (matched against both CamelCase and snake_case metric names)
### scope: global | datalog
###
filtering_rules:
  - policy: deny
    pattern: org.apache.cassandra.metrics.ThreadPools
    scope: global
  - policy: deny
    pattern: org.apache.cassandra.metrics.DroppedMessage
    scope: global
  - policy: allow
    pattern: .*
    scope: global

### Store metrics on local disk in addition to Prometheus scraping
write_to_disk_enabled: true

### Max on-disk storage for collected metrics (MB)
data_dir_max_size_in_mb: 5000

### Directory to store collected metrics (default: Cassandra data dir)
data_dir: {{ cassandra_data_dir }}

### Directory to store MCAC logs (default: Cassandra log dir)
log_dir: {{ mcac_log_dir }}
